{
  "name": "@velajs/cli",
  "version": "0.3.2",
  "description": "CLI for Vela apps — seeding and project tasks (Node-side; not bundled into the edge Worker)",
  "keywords": [
    "cli",
    "cloudflare-workers",
    "edge",
    "seeder",
    "vela"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velajs/cli.git"
  },
  "bin": {
    "vela": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:preflight": "npm view @velajs/vela@2.0.0 version",
    "release:check": "node scripts/check-release-lock.mjs && pnpm verify && pnpm audit --audit-level=high",
    "release": "pnpm release:preflight && pnpm release:check && changeset publish",
    "verify": "pnpm lint && pnpm format:check && pnpm build && pnpm typecheck && pnpm test && pnpm publint && pnpm attw"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "clipanion": "^4.0.0-rc.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@changesets/cli": "catalog:",
    "@swc/core": "catalog:",
    "@types/node": "catalog:",
    "@velajs/vela": "^2.0.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "publint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unplugin-swc": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@velajs/vela": ">=2.0.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.11.0"
}
